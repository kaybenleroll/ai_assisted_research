SOURCE_MD   := "silo_index.md"
PROJECT_DIR := "silo_rpg_primer"
TITLE       := "Silo RPG"
AUTHOR      := "Silo RPG"
HTML_EXTRA  := ""
PDF_EXTRA   := ""

import '../_shared/common.just'

# Multi-doc orchestration (shared html/pdf/all act on silo_index only)
silo-html: silo-index-html silo-player-html silo-gm-html silo-bible-html silo-campaign-html
silo-pdf: silo-index-pdf silo-player-pdf silo-gm-pdf silo-bible-pdf silo-campaign-pdf
silo-all: silo-html silo-pdf

silo-clobber:
  rm -fv silo_index.html silo_index.pdf \
         silo_player_guide.html silo_player_guide.pdf \
         silo_gm_secrets.html silo_gm_secrets.pdf \
         silo_comprehensive_bible.html silo_comprehensive_bible.pdf \
         silo_starter_campaign.html silo_starter_campaign.pdf

silo-index-html:
  {{OCI}} run --rm {{OCI_FLAGS}} \
    -v "{{REPO_ROOT}}:/repo{{MOUNT_SUFFIX}}" \
    -w "/repo/{{PROJECT_DIR}}" \
    {{IMAGE}} \
    silo_index.md -o silo_index.html \
    {{HTML_FLAGS_BASE}} \
    --template="{{TEMPLATE}}" \
    --metadata title="SILO RPG DOCUMENT INDEX" \
    --metadata author="{{AUTHOR}}"

silo-index-pdf:
  {{OCI}} run --rm {{OCI_FLAGS}} \
    -v "{{REPO_ROOT}}:/repo{{MOUNT_SUFFIX}}" \
    -w "/repo/{{PROJECT_DIR}}" \
    {{IMAGE}} \
    silo_index.md -o silo_index.pdf \
    {{PDF_FLAGS_BASE}} \
    --include-in-header="{{COMPACT_LATEX}}" \
    --metadata title="SILO RPG DOCUMENT INDEX" \
    --metadata author="{{AUTHOR}}"

