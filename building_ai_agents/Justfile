SOURCE_MD   := "ai_agents_comprehensive_primer.md"
PROJECT_DIR := "building_ai_agents"
TITLE       := "Building Autonomous AI Agents: A Comprehensive Primer"
AUTHOR      := "May 2026"
HTML_EXTRA  := "--mathjax --lua-filter=filters/mermaid-to-image.lua"
PDF_EXTRA   := "--lua-filter=filters/mermaid-to-image.lua -V mainfont='DejaVu Serif' -V sansfont='DejaVu Sans' -V monofont='DejaVu Sans Mono'"

import '../_shared/common.just'

MERMAID_FILTER := "filters/mermaid-to-image.lua"
REFERENCE_MD   := "agent_quick_reference.md"

# HTML math variants (different output filenames from shared html recipe)
html-mathml:
  {{OCI}} run --rm {{OCI_FLAGS}} \
    -v "{{REPO_ROOT}}:/repo{{MOUNT_SUFFIX}}" \
    -w "/repo/{{PROJECT_DIR}}" \
    {{IMAGE}} \
    {{SOURCE_MD}} -o ai_agents_comprehensive_primer.mathml.html \
    {{HTML_FLAGS_BASE}} --mathml --lua-filter="{{MERMAID_FILTER}}" \
    --template="{{TEMPLATE}}" \
    --metadata title="{{TITLE}}" \
    --metadata author="{{AUTHOR}}"

html-mathjax:
  {{OCI}} run --rm {{OCI_FLAGS}} \
    -v "{{REPO_ROOT}}:/repo{{MOUNT_SUFFIX}}" \
    -w "/repo/{{PROJECT_DIR}}" \
    {{IMAGE}} \
    {{SOURCE_MD}} -o ai_agents_comprehensive_primer.mathjax.html \
    {{HTML_FLAGS_BASE}} --mathjax --lua-filter="{{MERMAID_FILTER}}" \
    --template="{{TEMPLATE}}" \
    --metadata title="{{TITLE}}" \
    --metadata author="{{AUTHOR}}"

html-variants: html-mathml html-mathjax

# Companion quick reference document
quick-html:
  {{OCI}} run --rm {{OCI_FLAGS}} \
    -v "{{REPO_ROOT}}:/repo{{MOUNT_SUFFIX}}" \
    -w "/repo/{{PROJECT_DIR}}" \
    {{IMAGE}} \
    {{REFERENCE_MD}} -o agent_quick_reference.html \
    {{HTML_FLAGS_BASE}} --lua-filter="{{MERMAID_FILTER}}" \
    --template="{{TEMPLATE}}" \
    --metadata title="Agent Implementation Quick Reference" \
    --metadata author="{{AUTHOR}}"

# Backward-compat aliases
main-html: html
main-html-mathml: html-mathml
main-html-mathjax: html-mathjax
main-pdf: pdf
pdf-unicode: pdf
docs: quick-html
all-docs: docs
ref-html: quick-html
rebuild: clean all docs
