SOURCE_MD   := "numerical_analysis_primer.md"
PROJECT_DIR := "numerical_analysis_primer"
TITLE       := "Numerical Analysis Primer: A Practical Guide for Practitioners"
AUTHOR      := "June 2026"
HTML_EXTRA  := "--mathjax --lua-filter=filters/mermaid-to-image.lua --number-sections --shift-heading-level-by=-1"
PDF_EXTRA   := "--lua-filter=filters/mermaid-to-image.lua --number-sections --shift-heading-level-by=-1 --include-in-header=extra-fonts.latex"
ROCKER      := "docker.io/rocker/tidyverse:4.5.1"

# Generate R figures (inside rocker container)
plots:
  {{OCI}} run --rm {{OCI_FLAGS}} \
    -v "{{REPO_ROOT}}:/repo{{MOUNT_SUFFIX}}" \
    -w "/repo/{{PROJECT_DIR}}" \
    {{ROCKER}} \
    Rscript generate_plots.R

# Generate figures then render both HTML and PDF
full: plots html pdf

import '../_shared/common.just'

# HTML math variants (different output filenames from shared html recipe)
html-mathml:
  {{OCI}} run --rm {{OCI_FLAGS}} \
    -v "{{REPO_ROOT}}:/repo{{MOUNT_SUFFIX}}" \
    -w "/repo/{{PROJECT_DIR}}" \
    {{IMAGE}} \
    {{SOURCE_MD}} -o numerical_analysis_primer.mathml.html \
    {{HTML_FLAGS_BASE}} --mathml \
    --template="{{TEMPLATE}}" \
    --metadata title="{{TITLE}}" \
    --metadata author="{{AUTHOR}}"

html-mathjax:
  {{OCI}} run --rm {{OCI_FLAGS}} \
    -v "{{REPO_ROOT}}:/repo{{MOUNT_SUFFIX}}" \
    -w "/repo/{{PROJECT_DIR}}" \
    {{IMAGE}} \
    {{SOURCE_MD}} -o numerical_analysis_primer.mathjax.html \
    {{HTML_FLAGS_BASE}} --mathjax \
    --template="{{TEMPLATE}}" \
    --metadata title="{{TITLE}}" \
    --metadata author="{{AUTHOR}}"

html-variants: html-mathml html-mathjax
